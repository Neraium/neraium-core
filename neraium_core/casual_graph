import numpy as np


def causal_graph_metrics(C: np.ndarray, threshold: float = 0.1) -> dict:
    A = np.array(C)
    A[np.abs(A) < threshold] = 0
    np.fill_diagonal(A, 0)

    density = float(np.mean(np.abs(A) > 0))
    asymmetry = float(np.mean(np.abs(A - A.T)))
    outbound = np.sum(np.abs(A), axis=1)

    dominant = np.argsort(-outbound)[:3].tolist()

    return {
        "density": density,
        "asymmetry": asymmetry,
        "dominant_sources": dominant,
    }